# OpenRouter API Key (required for both LLM and embeddings)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# LLM Model (optional, defaults to openai/gpt-4-turbo-preview)
OPENROUTER_LLM_MODEL=openai/gpt-4-turbo-preview

# Embedding Model (optional, defaults to openai/text-embedding-3-small)
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Application Settings (optional)
LOG_LEVEL=info
MAX_ITERATIONS=10
TEMPERATURE=0.7
MAX_TOKENS=2048
MEMORY_SIZE=20
