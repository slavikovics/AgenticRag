# OpenRouter API Key (REQUIRED) - Get yours from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-actual-api-key-here

# OpenRouter LLM Model (optional, defaults to openai/gpt-4-turbo-preview)
OPENROUTER_LLM_MODEL=openai/gpt-4-turbo-preview

# OpenRouter Embedding Model (optional, defaults to openai/text-embedding-3-small)
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Qdrant URL (optional, defaults to http://localhost:6333)
# When using docker-compose, use http://qdrant:6333
QDRANT_URL=http://qdrant:6333

# Qdrant Collection Name (optional, defaults to documents)
QDRANT_COLLECTION_NAME=documents

# Qdrant Mode (optional, set to 'memory' for in-memory mode without Docker)
# Set to 'memory' if you don't have Docker or want to run without Qdrant server
QDRANT_MODE=remote

# Application Settings (optional)
LOG_LEVEL=info
MAX_ITERATIONS=10
TEMPERATURE=0.7
MAX_TOKENS=2048
MEMORY_SIZE=20
